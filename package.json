{
  "name": "eq-shell",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "vite",
    "build:packages": "pnpm -r --filter \"./eq-intake/eq-platform/packages/**\" run build",
    "build:tokens": "node scripts/build-public-tokens.mjs",
    "check:perms": "node scripts/check-perm-sync.mjs",
    "build": "pnpm run build:packages && pnpm run build:tokens && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-functions.mjs",
    "check:css": "node scripts/check-css-coverage.mjs"
  },
  "dependencies": {
    "@eq-solutions/roles": "github:eq-solutions/eq-roles#v2.0.0",
    "@eq-solutions/tokens": "github:eq-solutions/eq-design-tokens#v1.3.1",
    "@eq-solutions/ui": "github:eq-solutions/eq-ui#v1.1.1",
    "@eq/ai": "workspace:*",
    "@eq/confirm-ui": "workspace:*",
    "@eq/intake": "workspace:*",
    "@eq/intake-demo": "workspace:*",
    "@eq/schemas": "workspace:*",
    "@eq/validation": "workspace:*",
    "@sentry/node": "^10.53.1",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.106.0",
    "bcryptjs": "^3.0.3",
    "google-auth-library": "^10.6.2",
    "lucide-react": "^1.16.0",
    "qrcode": "^1.5.4",
    "react-hook-form": "^7.76.0",
    "posthog-js": "^1.374.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^6.30.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@netlify/functions": "^5.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/qrcode": "^1.5.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
