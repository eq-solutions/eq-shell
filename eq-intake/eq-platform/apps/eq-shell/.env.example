# Copy to `.env.local` (gitignored) and fill in the demo Supabase creds.
# DO NOT put SKS credentials in this file — SKS creds belong only in the
# SKS Netlify site's env vars, never on this laptop.

# Tenant identity — controls header label + palette + enabled modules
VITE_TENANT=demo
VITE_TENANT_NAME=EQ Demo
VITE_ENABLED_MODULES=intake,quotes

# Demo Supabase project (eq-demo-canonical, Sydney region)
# Get these from Supabase dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://YOUR-DEMO-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-DEMO-ANON-KEY
