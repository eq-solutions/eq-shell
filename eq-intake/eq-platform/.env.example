# Copy this file to `.env` (same directory) and paste your real key.
# `.env` is gitignored — `.env.example` is committed as documentation.
#
# Get a key at https://console.anthropic.com/ -> Settings -> API keys.
# Set a monthly spend cap in Settings -> Billing before wiring it up.

ANTHROPIC_API_KEY=sk-ant-api03-PASTE-YOUR-KEY-HERE

# Optional: model overrides for the AnthropicProvider defaults.
# Leave commented out to use the package defaults (claude-sonnet-4-5 for
# both map and extract; claude-opus-4-7 as the escalation model).
#
# EQ_AI_MAP_MODEL=claude-sonnet-4-5
# EQ_AI_EXTRACT_MODEL=claude-sonnet-4-5
# EQ_AI_EXTRACT_ESCALATION_MODEL=claude-opus-4-7
