# EQ Shell — required environment variables
#
# Local dev: copy this to `.env` (which is gitignored) and fill in values
# from the Supabase dashboard (Settings → API) and the Netlify dashboard
# (Site settings → Environment variables).
#
# Production: set the same names + values on the Netlify deploy.

# Browser-side — exposed to the bundle, safe for public reads.
# Used by src/supabase.ts to construct the Supabase client.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase anon public key>

# Server-side only — Netlify functions.
# Used by getServiceClient() to talk to Supabase as service-role.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase service_role key — NEVER expose to browser>

# Server-side only — Netlify functions.
# HMAC secret for the eq_shell_session cookie + iframe handoff token.
# MUST match the value used by the eq-solves-field deploy for the
# cross-domain iframe handshake to verify.
EQ_SECRET_SALT=<shared salt with eq-solves-field>

# Server-side only — Netlify functions.
# Used by signSupabaseJwt() to mint Supabase-format JWTs that the
# browser sends to Supabase. Find in Supabase dashboard under
# Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=<supabase JWT secret>
