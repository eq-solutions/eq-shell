# EQ Shell — environment variable template.
#
# Copy to `.env.local` for `netlify dev` / `vite dev`, or set the same vars
# on the Netlify project for production. NEVER commit real values — only
# the placeholder names live here.
#
# Vars prefixed `VITE_` are exposed to the browser bundle by Vite.
# Everything else is server-side (Netlify Functions) only.

# --- Supabase (canonical: eq-canonical / jvknxcmbtrfnxfrwfimn) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (SKS tenant data plane: sks-canonical / ehowgjardagevnrluult) ---
# Required for the Intake module — entity data lives here, not on eq-canonical.
VITE_SKS_SUPABASE_URL=https://ehowgjardagevnrluult.supabase.co
VITE_SKS_SUPABASE_ANON_KEY=
# Server-side only — sks-canonical JWT secret (Settings → API → JWT Secret).
# Used by mint-sks-jwt to issue tokens the Intake module sends to sks-canonical.
SKS_SUPABASE_JWT_SECRET=

# --- Shell auth ---
EQ_SECRET_SALT=
SUPABASE_JWT_SECRET=

# --- Transactional email ---
# Set EQ_EMAIL_PROVIDER=resend to enable real delivery. Unset = log-only fallback.
EQ_EMAIL_PROVIDER=
# Resend API key — https://resend.com/api-keys (keep in Netlify env, never in source)
RESEND_API_KEY=
# Optional: override the From address (default: "EQ Solutions <noreply@eq.solutions>")
EMAIL_FROM=

# --- Observability: Sentry ---
# Org slug `eq-solutions`, project slug `eq-shell`. Alerts route to dev@eq.solutions.
# See docs/runbooks/sentry-setup.md.
VITE_SENTRY_DSN=
# Optional — defaults to import.meta.env.MODE (dev / production)
VITE_SENTRY_ENVIRONMENT=
# Optional — release tag (typically the git SHA)
VITE_SENTRY_RELEASE=
# Server-side (Netlify Functions). Usually the same DSN as the browser.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Optional override for server traces sample rate (default 0.1)
SENTRY_TRACES_SAMPLE_RATE=

# --- Observability: PostHog ---
# EU instance. Separate keys per environment (dev/preview vs production).
# See docs/runbooks/posthog-setup.md.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# --- Observability: Microsoft Clarity ---
# Project ID (the short alphanumeric string at the end of the Clarity dashboard URL).
# See docs/runbooks/clarity-setup.md.
VITE_CLARITY_PROJECT_ID=
